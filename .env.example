# SentinelCore Environment Variables Example
# Copy this file to .env and fill in the values

# API Keys
VIRUSTOTAL_API_KEY=your_virustotal_key_here
LEAKLOOKUP_API_KEY=your_leaklookup_key_here
NVIDIA_NIM_API_KEY=your_nvidia_nim_key_here

# App Settings
DEBUG=true
APP_NAME=SentinelCore
APP_VERSION=4.0

# Database
DATABASE_URL=sqlite:///./sentinelcore.db

# Models
NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct
DEEPFAKE_MODEL=prithivMLmods/Deep-Fake-Detector-Model

# Operations
RECON_CONTAINER_NAME=sentinelcore-recon-agent
RECON_DOCKER_IMAGE=sentinelcore-recon:latest
REPORTS_DIR=./reports
MAX_CONCURRENT_RECON_JOBS=3
